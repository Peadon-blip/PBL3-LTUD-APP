<Page x:Class="StudentReminderApp.Views.Pages.CoursePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Đăng ký học phần"
      Background="{StaticResource BgBrush}">
    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="3"
                Background="#80FFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="10">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="100"
                             Height="10"/>
                <TextBlock Text="Đang tải dữ liệu..."
                           Margin="0,10,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,24">
            <TextBlock Text="Đăng ký học phần"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Xem danh sách các lớp học phần đang mở và tiến hành đăng ký."
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="0,0,0,16"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Học kỳ:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CmbHocKy"
                          Grid.Column="2"
                          Height="36"
                          Background="White"
                          BorderBrush="#E2E8F0"
                          Padding="8,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3 (Hè)"/>
                </ComboBox>

                <TextBlock Grid.Column="4"
                           Text="Năm học:"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="CmbNamHoc"
                          Grid.Column="6"
                          Height="36"
                          Background="White"
                          BorderBrush="#E2E8F0"
                          Padding="8,0"
                          SelectedIndex="1">
                    <ComboBoxItem Content="2023-2024"/>
                    <ComboBoxItem Content="2024-2025"/>
                    <ComboBoxItem Content="2025-2026"/>
                </ComboBox>

                <Button Grid.Column="8"
                        Content="Lọc danh sách"
                        Style="{StaticResource BtnPrimary}"
                        Height="36"
                        Padding="24,0"
                        Click="BtnLoadCourses_Click"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                Padding="0">
            <DataGrid x:Name="DgCourses"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0"
                      CanUserResizeRows="False"
                      RowHeight="48"
                      FontSize="13"
                      Margin="0,10,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã MH"
                                        Binding="{Binding MaMonHocDisplay}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Tên môn học"
                                        Binding="{Binding TenMonHoc}"
                                        Width="*"/>
                    <DataGridTextColumn Header="TC"
                                        Binding="{Binding SoTinChi}"
                                        Width="50"/>
                    <DataGridTextColumn Header="Giảng viên"
                                        Binding="{Binding TenGiangVien}"
                                        Width="160"/>
                    <DataGridTextColumn Header="Lịch học"
                                        Width="180">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="Thứ {0} (Tiết {1}-{2}) · {3}">
                                <Binding Path="ThuTrongTuan"/>
                                <Binding Path="TietBatDau"/>
                                <Binding Path="TietKetThuc"/>
                                <Binding Path="TenPhong"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Trạng thái"
                                        Binding="{Binding TrangThaiText}"
                                        Width="100"/>
                    <DataGridTemplateColumn Header="Thao tác"
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button Content="Đăng ký"
                                            Height="32"
                                            Padding="12,0"
                                            Click="BtnRegister_Click"
                                            Tag="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource BtnPrimary}">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DaDangKy}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Nút hủy (Hiện khi đã đăng ký) -->
                                    <Button Content="Hủy"
                                            Background="{StaticResource DangerBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Height="32"
                                            Padding="12,0"
                                            Click="BtnUnregister_Click"
                                            Tag="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DaDangKy}"
                                                                 Value="True">
                                                        <Setter Property="Visibility"
                                                                Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius"
                                                        Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>